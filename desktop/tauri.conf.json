{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kivo",
  "version": "0.3.3",
  "identifier": "com.kivo.app",
  "build": {
    "beforeDevCommand": "pnpm frontend:dev",
    "beforeBuildCommand": "pnpm frontend:build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kivo",
        "width": 1180,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dexter-xD/Kivo/releases/latest/download/latest.json"
      ],
      "pubkey": "RWQnhSei4viItSTcmjhdmRhnRaWgFGQ69RzjTYF7lP/g3KXWEq+yt70F"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi",
      "nsis",
      "deb"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "languages": [
          "English"
        ]
      },
      "wix": {
        "language": [
          "en-US"
        ]
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}